 # TokUp · 脉充 — 环境变量
 # 复制此文件为 .env 并修改
 
 # 安全：JWT 签名密钥（生产环境必须改为强随机字符串）
 TOKUP_SECRET_KEY=
 
 # CORS：允许的前端域名（逗号分隔）
 TOKUP_ALLOWED_ORIGINS=http://localhost:3000,https://tokup.io
 
 # 安全：允许的主机头（逗号分隔）
 TOKUP_ALLOWED_HOSTS=localhost,tokup.io,api.tokup.io
 
 # 数据库（生产环境请用 PostgreSQL）
 TOKUP_DATABASE_URL=sqlite:///./tokup.db
 
 # 管理员账号（启动时自动创建，留空则不创建）
 TOKUP_ADMIN_EMAIL=admin@tokup.io
 TOKUP_ADMIN_PASSWORD=请修改为强密码
 
 # AI API 密钥
 OPENAI_API_KEY=
 ANTHROPIC_API_KEY=
 DEEPSEEK_API_KEY=
