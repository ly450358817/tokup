# TokUp · 脉充 — 环境配置

# 数据库
TOKUP_DATABASE_URL=sqlite:///./tokup.db

# JWT 密钥
TOKUP_SECRET_KEY=your-secret-key-change-this

# 管理员账号（启动时自动创建）
TOKUP_ADMIN_EMAIL=admin@tokup.io
TOKUP_ADMIN_PASSWORD=Admin123456

# 允许的来源域名（前端地址）
TOKUP_ALLOWED_ORIGINS=http://localhost:3000,https://tokup.io

# 允许的主机名
TOKUP_ALLOWED_HOSTS=localhost,tokup.io,api.tokup.io

# 虎皮椒支付配置（https://www.xmpay.com）
XMPAY_URL=https://api.xmpay.com/api/pay
XMPAY_APP_ID=your_pay_id_here
XMPAY_APP_SECRET=your_app_secret_here

# 网站基础URL（用于支付回调）
TOKUP_BASE_URL=http://localhost:3000

# AI API Keys（代理用）
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
DEEPSEEK_API_KEY=sk-your-deepseek-key

# 安全配置
TOKUP_SECURITY_LEVEL=high
TOKUP_RATE_LIMIT=60
TOKUP_BURST_LIMIT=10
TOKUP_ENABLE_AI_SECURITY=true
